{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "ruff": {
      "command": ["ruff", "format", "$FILE"],
      "extensions": [".py", ".pyi"]
    },
    "uv": {
      "disabled": true
    }
  },

  // "enabled_providers": ["volcengine", "coco-gemini", "coco-gpt", "google", "openai"],

  // use `curl https://models.dev/api.json` to see the default model configs
  "provider": {
    // https://www.packyapi.com/console
    "packyapi-claude": {
      "name": "packyapi-claude",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api-slb.packyapi.com/v1",
        "apiKey": "{env:PACKYAPI_CLAUDE_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "claude-sonnet-4-6",
          "modalities": { "input": [ "text", "image" ], "output": [ "text" ] },
          "limit": { "context": 1000000, "output": 64000 }
        }
      }
    },
    "packyapi-codex": {
      "name": "packyapi-codex",
      "npm": "@ai-sdk/openai",
      "options": {
        // "baseURL": "https://www.packyapi.com/v1",
        "baseURL": "https://api-slb.packyapi.com/v1",
        "apiKey": "{env:PACKYAPI_CODEX_API_KEY}"
      },
      "models": {
        "gpt-5.3-codex": {
          "name": "gpt-5.3-codex",
          "modalities": { "input": [ "text", "image" ], "output": [ "text" ] },
          "limit": { "context": 400000, "output": 128000 }
        }
      }
    },
    "coco-gemini": {
      "npm": "@ai-sdk/google",
      "name": "coco (Gemini family)",
      "options": {
        "baseURL": "http://localhost:9998/v1",
        "apiKey": "secret"
      },
      "models": {
        "gemini-3-pro-preview-new": {
          "name": "Gemini Pro",
          "modalities": { "input": [ "text", "image" ], "output": [ "text" ] },
          "limit": { "context": 1048576, "output": 65536 }
        }
      }
    },
    "coco-gpt": {
      "npm": "@ai-sdk/openai",
      "name": "coco (GPT family)",
      "options": {
        "baseURL": "http://localhost:9998/v1",
        "apiKey": "secret"
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT-5.2",
          "modalities": { "input": [ "text", "image" ], "output": [ "text" ] },
          "limit": { "context": 400000, "output": 128000 }
        }
      }
    },
    "volcengine": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "volcengine",
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "apiKey": "{env:ARK_API_KEY}"
      },
      "models": {
        "ark-code-latest": {
          "name": "Ark-Code",
          "limit": { "context": 256000, "output": 256000 },
          "options": { "thinking": { "type": "enabled" } }
        }
      }
    },
    "google": {
      // https://github.com/jenslys/opencode-gemini-auth/issues/38
      "options": {
        "projectId": "gen-lang-client-0101595700"
      }
    }
  },

  "plugin": [
    "opencode-openai-codex-auth@latest",
    "opencode-gemini-auth@latest",
    // Both oh-my-opencode and opencode-notifier listen to session.idle events.
    // Running both simultaneously can cause crashes on Windows.
    "@mohak34/opencode-notifier@latest"
    // "oh-my-opencode"
  ],

  "permission": {
    "external_directory": "ask",
    "doom_loop": "ask",
    "edit": "allow",

    // WARN: be aware of the web security
    "webfetch": "allow",
    "websearch": "allow",

    "bash": {
      "*": "ask",

      "pwd *": "allow",
      "sort *": "allow",
      "mv *": "allow",
      "cp *": "allow",
      "wc *": "allow",
      "date *": "allow",
      "touch *": "allow",
      "mkdir *": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "pcregrep *": "allow",
      "read *": "allow",
      "tree *": "allow",
      "test *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "curl *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "tee *": "allow",
      "sleep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sed *": "allow",
      "find *": "allow",
      "xargs find *": "allow",
      "fd *": "allow",
      "awk *": "allow",
      "which *": "allow",
      "sort *": "allow",

      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git blame *": "allow",
      "git status *": "allow",
      "git show *": "allow",

      "workspace/run.sh *": "allow",
      "latexmk *": "allow",
      "make *": "allow",
      "uv *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "pytest *": "allow",
      "go build *": "allow",
      "npm install *": "allow",
      "npx *": "allow",
      "npm run *": "allow"
    }
  },

  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey={env:EXA_API_KEY}",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--proxy-server=http://localhost:7890"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY"
      },
      "enabled": false
    }
  }
}
